 # Monorepo root .gitignore
# Each sub-project also has its own .gitignore for project-specific rules.

# Node modules across all sub-projects
**/node_modules/

# Next.js build output (portal)
portal/.next/
portal/out/
portal/.vercel/
portal/tsconfig.tsbuildinfo

# Vite/React build output (dashboard)
dashboard/dist/
dashboard/.vercel/

# Backend build output
backend/dist/

# Environment files — never commit secrets
**/.env
**/.env.local
**/.env.*.local
**/.env.production

# macOS system files
**/.DS_Store
*.pem

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# Editor directories
.vscode/
.idea/

# TypeScript build info
**/*.tsbuildinfo

# Vercel
.vercel
